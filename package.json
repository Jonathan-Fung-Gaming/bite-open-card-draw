{
  "name": "bite-open-card-draw",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "node scripts/run-playwright.mjs --profile=memory-dev-smoke test",
    "test:e2e:no-build": "node scripts/run-playwright.mjs --profile=memory-dev-smoke --skip-build test",
    "test:e2e:memory-dev-smoke": "node scripts/run-playwright.mjs --profile=memory-dev-smoke test",
    "test:e2e:production-flow": "node scripts/run-playwright.mjs --profile=production-flow test --config=playwright.phase9.config.ts --grep \"@full\"",
    "test:e2e:production-flow:validate": "node scripts/run-playwright.mjs --profile=production-flow --validate-env-only test --config=playwright.phase9.config.ts --grep \"@full\"",
    "test:load": "npm run test:load:api-injection",
    "test:load:api-injection": "node scripts/run-playwright.mjs --profile=memory-dev-smoke test --config=playwright.load.config.ts --grep \"@api-injection\"",
    "test:load:player-routes": "node scripts/run-playwright.mjs --profile=memory-dev-smoke test --config=playwright.load.config.ts --grep \"@player-route\"",
    "test:phase9": "node scripts/run-playwright.mjs --profile=memory-dev-smoke test --config=playwright.phase9.config.ts --grep \"@smoke\"",
    "test:phase9:supabase-dev": "node scripts/run-playwright.mjs --profile=supabase-dev-rehearsal test --config=playwright.phase9.config.ts --grep \"@smoke\"",
    "test:phase9:full": "node scripts/run-playwright.mjs --profile=supabase-dev-rehearsal test --config=playwright.phase9.config.ts --grep \"@full\"",
    "start": "next start",
    "build": "next build",
    "import:charts": "tsx scripts/import-charts.ts",
    "cache:chart-images": "node --use-system-ca --import tsx scripts/cache-chart-images.ts",
    "verify:real-chart-images": "tsx scripts/verify-real-chart-images.ts",
    "verify:release-data": "tsx scripts/verify-release-data.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.2",
    "@types/qrcode": "^1.5.6",
    "clsx": "^2.1.1",
    "csv-parse": "^7.0.0",
    "lucide-react": "^0.468.0",
    "next": "^15.3.3",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "server-only": "^0.0.1",
    "zod": "^4.4.3"
  },
  "overrides": {
    "postcss": "^8.5.10"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^22.15.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.25.0",
    "eslint-config-next": "^15.3.3",
    "postcss": "^8.5.10",
    "prettier": "^3.5.3",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.22.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  }
}
