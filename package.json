{
  "name": "bite-open-card-draw",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "node scripts/run-playwright.mjs --profile=memory-dev-smoke test",
    "test:e2e:no-build": "node scripts/run-playwright.mjs --profile=memory-dev-smoke --skip-build test",
    "test:e2e:memory-dev-smoke": "node scripts/run-playwright.mjs --profile=memory-dev-smoke test",
    "test:phase0:memory": "node scripts/run-playwright.mjs --profile=memory-dev-smoke test --config=playwright.phase0.config.ts --grep @phase0-memory",
    "test:phase0:memory:chromium": "node scripts/run-playwright.mjs --profile=memory-dev-smoke test --config=playwright.phase0.config.ts --grep @phase0-memory --project=phase0-visual-chromium",
    "test:phase0:memory:webkit": "node scripts/run-playwright.mjs --profile=memory-dev-smoke test --config=playwright.phase0.config.ts --grep @phase0-memory --project=phase0-visual-webkit",
    "test:phase0:hosted": "node scripts/run-phase0-diagnostics.mjs",
    "test:phase0:hosted:list": "node scripts/run-phase0-diagnostics.mjs --list",
    "test:phase1:memory": "node scripts/run-playwright.mjs --profile=phase1-memory test --config=playwright.phase1.config.ts --grep @phase1",
    "test:phase1:hosted": "node scripts/run-playwright.mjs --profile=phase1-supabase test --config=playwright.phase1.config.ts --grep @phase1",
    "test:phase1:hosted:cache-zero": "node scripts/run-playwright.mjs --profile=phase1-supabase-cache-zero test --config=playwright.phase1.config.ts --grep @phase1",
    "test:phase1:hosted:cache-max": "node scripts/run-playwright.mjs --profile=phase1-supabase-cache-max test --config=playwright.phase1.config.ts --grep @phase1",
    "test:phase2:memory": "node scripts/run-playwright.mjs --profile=phase2-memory test --config=playwright.phase2.config.ts --grep @phase2",
    "test:phase2:memory:list": "node scripts/run-playwright.mjs --profile=phase2-memory test --config=playwright.phase2.config.ts --grep @phase2 --list",
    "test:phase3:memory": "node scripts/run-playwright.mjs --profile=phase3-memory test --config=playwright.phase3.config.ts --grep @phase3-memory",
    "test:phase3:memory:list": "node scripts/run-playwright.mjs --profile=phase3-memory test --config=playwright.phase3.config.ts --grep @phase3-memory --list",
    "test:phase3:hosted": "node scripts/run-phase3-hosted.mjs",
    "test:phase3:hosted:list": "node scripts/run-phase3-hosted.mjs --list",
    "test:phase3:soak": "node scripts/run-phase3-soak.mjs",
    "test:phase3:soak:real": "node scripts/run-phase3-soak.mjs --real",
    "test:phase4:memory": "node scripts/run-playwright.mjs --profile=phase4-memory test --config=playwright.phase4.config.ts --grep @phase4-memory",
    "test:phase4:memory:list": "node scripts/run-playwright.mjs --profile=phase4-memory test --config=playwright.phase4.config.ts --grep @phase4-memory --list",
    "test:phase4:hosted": "node scripts/run-phase4-hosted.mjs",
    "test:phase4:hosted:list": "node scripts/run-phase4-hosted.mjs --list",
    "test:phase5:memory": "node scripts/run-playwright.mjs --profile=phase5-memory test --config=playwright.phase5.config.ts --grep @phase5",
    "test:phase5:memory:list": "node scripts/run-playwright.mjs --profile=phase5-memory test --config=playwright.phase5.config.ts --grep @phase5 --list",
    "test:phase5:chromium": "node scripts/run-playwright.mjs --profile=phase5-memory test --config=playwright.phase5.config.ts --grep @phase5 --project=phase5-desktop-chromium --project=phase5-mobile-chromium",
    "test:phase5:webkit": "node scripts/run-playwright.mjs --profile=phase5-memory test --config=playwright.phase5.config.ts --grep @phase5 --project=phase5-mobile-webkit",
    "test:e2e:production-flow": "node scripts/run-playwright.mjs --profile=production-flow test --config=playwright.phase9.config.ts --grep \"@full\"",
    "test:e2e:production-flow:list": "node scripts/run-playwright.mjs --profile=production-flow test --config=playwright.phase9.config.ts --grep \"@full\" --list",
    "test:e2e:production-flow:validate": "node scripts/run-playwright.mjs --profile=production-flow test --config=playwright.phase9.config.ts --grep \"@validate\"",
    "test:load": "npm run test:load:api-injection",
    "test:load:api-injection": "node scripts/run-playwright.mjs --profile=memory-dev-smoke test --config=playwright.load.config.ts --grep \"@api-injection\"",
    "test:load:player-routes": "node scripts/run-playwright.mjs --profile=memory-dev-smoke test --config=playwright.load.config.ts --grep \"@player-route\"",
    "test:phase9": "node scripts/run-playwright.mjs --profile=memory-dev-smoke test --config=playwright.phase9.config.ts --grep \"@smoke\"",
    "test:phase9:supabase-dev": "node scripts/run-playwright.mjs --profile=supabase-dev-rehearsal test --config=playwright.phase9.config.ts --grep \"@supabase-smoke\"",
    "test:diagnostic:supabase-dev-full": "node scripts/run-playwright.mjs --profile=supabase-dev-rehearsal test --config=playwright.phase9.config.ts --grep \"@full\"",
    "start": "next start",
    "build": "next build",
    "import:charts": "tsx scripts/import-charts.ts",
    "cache:chart-images": "node --use-system-ca --import tsx scripts/cache-chart-images.ts",
    "verify:real-chart-images": "tsx scripts/verify-real-chart-images.ts",
    "verify:release-data": "tsx scripts/verify-release-data.ts",
    "supabase:version": "npx supabase --version",
    "supabase:status": "npx supabase status",
    "supabase:migration:list": "npx supabase migration list",
    "supabase:db:push": "npx supabase db push",
    "supabase:db:lint": "npx supabase db lint"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.2",
    "@types/qrcode": "^1.5.6",
    "clsx": "^2.1.1",
    "csv-parse": "^7.0.0",
    "lucide-react": "^0.468.0",
    "next": "^15.3.3",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "server-only": "^0.0.1",
    "zod": "^4.4.3"
  },
  "overrides": {
    "postcss": "^8.5.10"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^22.15.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.25.0",
    "eslint-config-next": "^15.3.3",
    "postcss": "^8.5.10",
    "prettier": "^3.5.3",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.22.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  }
}
