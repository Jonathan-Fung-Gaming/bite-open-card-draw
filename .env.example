# Public app URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase public browser-safe values
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only Supabase key. Never expose to browser code.
SUPABASE_SERVICE_ROLE_KEY=

# Admin auth. Store a hash, not a plaintext password.
# Supported local hash format: scrypt:v1:<salt_hex>:<hash_hex>
ADMIN_PASSWORD_HASH=

# Server-side session signing secret.
SESSION_SECRET=

# Required event namespace for rehearsals/production once normalized repositories are enabled.
TOURNAMENT_EVENT_ID=local-dev

# Use `supabase` for event/deployed operation. Production rejects `memory`.
# Tests and local demos can leave this as `memory`.
TOURNAMENT_STATE_BACKEND=memory

# Optional Supabase read-I/O protection. Defaults are 1000 ms and capped at 5000 ms.
# Set either value to 0 only for diagnostics when every read must bypass the cache.
TOURNAMENT_PUBLIC_READ_CACHE_MS=
TOURNAMENT_DATABASE_TIME_CACHE_MS=

# Optional non-production e2e helper token. Do not set this in production.
TOURNAMENT_TEST_ROUTE_TOKEN=

# Optional admin rehearsal controls. Leave unset for the real event. When set to true, the event id
# must be disposable and start with e2e-, phase9-, load-, or rehearsal-.
TOURNAMENT_ALLOW_REHEARSAL_ADMIN_CONTROLS=

# Optional local settings
NODE_ENV=development

# Protein Tracker scheduled Web Push Edge Function only. Keep disabled until Phase 8.5 deployment,
# secret provisioning, and cron configuration are complete. All values below are server-only.
PROTEIN_SCHEDULED_PUSH_ENABLED=false
PROTEIN_SCHEDULE_AUTH_TOKEN=
SUPABASE_URL=
SUPABASE_SECRET_KEY=
VAPID_SUBJECT=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
